<!-- Modal Confirmar -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalTitle">Confirmar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="deleteModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="deleteForm" method="POST" style="display:inline;">
                    @csrf
                    <input type="hidden" name="_method" id="deleteMethod" value="DELETE">
                    <button type="submit" class="btn btn-danger" id="deleteModalBtn">Aceptar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Inicializar modales para evitar errores de backdrop
        const modals = ['createModal', 'editModal', 'importModal', 'deleteModal'];
        modals.forEach(id => {
            const modalEl = document.getElementById(id);
            if (modalEl) {
                new bootstrap.Modal(modalEl);
            }
        });

        // Filtros con fetch (sin recargar página)
        let timeout = null;
        const nombreInput = document.getElementById('filterNombre');
        const generoSelect = document.getElementById('filterGenero');
        const estadoSelect = document.getElementById('filterEstado');
        const tablaContainer = document.getElementById('tabla-container');

        function cargarMaestros() {
            const params = new URLSearchParams({
                nombre: nombreInput.value,
                genero: generoSelect.value,
                estado: estadoSelect.value,
                ajax: 1
            });
            fetch(`{{ route('maestros.index') }}?${params.toString()}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => response.text())
            .then(html => {
                tablaContainer.innerHTML = html;
            })
            .catch(console.error);
        }

        nombreInput.addEventListener('input', () => {
            clearTimeout(timeout);
            timeout = setTimeout(cargarMaestros, 500);
        });
        generoSelect.addEventListener('change', cargarMaestros);
        estadoSelect.addEventListener('change', cargarMaestros);

        // Delegación de eventos para botones de editar/eliminar/reactivar
        tablaContainer.addEventListener('click', function(e) {
            // Botón editar
            if (e.target.closest('.edit-btn')) {
                const btn = e.target.closest('.edit-btn');
                document.getElementById('editForm').action = `/maestros/${btn.dataset.id}`;
                document.getElementById('edit_name').value = btn.dataset.name;
                document.getElementById('edit_genero').value = btn.dataset.genero;
                document.getElementById('edit_tutelado').value = btn.dataset.tutelado;
                document.getElementById('edit_estado').value = btn.dataset.estado;
                new bootstrap.Modal(document.getElementById('editModal')).show();
            }
            // Botón eliminar/reactivar
            if (e.target.closest('.delete-btn') || e.target.closest('.reactivar-btn')) {
                const btn = e.target.closest('.delete-btn') || e.target.closest('.reactivar-btn');
                const id = btn.dataset.id;
                const nombre = btn.dataset.nombre;
                const tipo = btn.dataset.tipo;
                const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                if (tipo === 'eliminar') {
                    document.getElementById('deleteModalTitle').innerText = 'Confirmar desactivación';
                    document.getElementById('deleteModalBody').innerText = `¿Desactivar al maestro "${nombre}"?`;
                    document.getElementById('deleteModalBtn').innerText = 'Desactivar';
                    document.getElementById('deleteModalBtn').className = 'btn btn-danger';
                    document.getElementById('deleteForm').action = `/maestros/${id}`;
                    document.getElementById('deleteMethod').value = 'DELETE';
                } else {
                    document.getElementById('deleteModalTitle').innerText = 'Confirmar reactivación';
                    document.getElementById('deleteModalBody').innerText = `¿Reactivar al maestro "${nombre}"?`;
                    document.getElementById('deleteModalBtn').innerText = 'Reactivar';
                    document.getElementById('deleteModalBtn').className = 'btn btn-success';
                    document.getElementById('deleteForm').action = `/maestros/${id}/reactivar`;
                    document.getElementById('deleteMethod').value = 'PATCH';
                }
                modal.show();
            }
        });

        // Envío de formularios vía AJAX (crear, editar, importar)
        document.getElementById('createForm')?.addEventListener('submit', enviarFormulario);
        document.getElementById('editForm')?.addEventListener('submit', enviarFormulario);
        document.getElementById('importForm')?.addEventListener('submit', enviarFormulario);
        document.getElementById('deleteForm')?.addEventListener('submit', enviarFormulario);

        function enviarFormulario(e) {
            e.preventDefault();
            const form = e.target;
            const formData = new FormData(form);
            fetch(form.action, {
                method: form.method,
                body: formData,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    cargarMaestros();
                    // Cerrar todos los modales
                    document.querySelectorAll('.modal').forEach(modal => {
                        bootstrap.Modal.getInstance(modal)?.hide();
                    });
                    mostrarAlerta(data.success, 'success');
                } else {
                    mostrarAlerta(data.error || 'Error en la operación', 'danger');
                }
            })
            .catch(error => {
                console.error(error);
                mostrarAlerta('Error de conexión', 'danger');
            });
        }

        function mostrarAlerta(mensaje, tipo) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${tipo} alert-dismissible fade show`;
            alertDiv.innerHTML = `${mensaje}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
            const container = document.getElementById('alert-container');
            container.innerHTML = '';
            container.appendChild(alertDiv);
            setTimeout(() => alertDiv.remove(), 5000);
        }
    });
</script>
@endsection
